# eval/.env.example — Copy to .env and fill in your values
# Usage: cp .env.example .env && nano .env

# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key (for blind-eval and auto-iteration Claude API calls)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Eval Settings ───────────────────────────────────────────────────────────

# Target accuracy to stop iteration (0.0 to 1.0)
TARGET_ACCURACY=0.90

# Maximum iteration loops before stopping
MAX_ITERATIONS=30

# Claude model for diagnosis/patching
MODEL_NAME=claude-sonnet-4-6

# Number of sheets to evaluate concurrently
EVAL_CONCURRENCY=6

# ─── Path Overrides (usually auto-detected) ──────────────────────────────────

# Path to rust-parser binary (auto-detected: ../pipelines/rust/target/release/rust-parser)
# RUST_PARSER_BIN=/path/to/rust-parser

# Path to Rust source directory (for auto-iteration patching)
# RUST_SRC_DIR=/path/to/pipelines/rust

# Directory containing .xlsx model files
# MODELS_DIR=./models

# Output directory for results
# OUTPUT_DIR=./output

# ─── Pipeline Settings ──────────────────────────────────────────────────────

# WebSocket port for monitor dashboard (0 = disabled)
# WS_PORT=3001

# Minimum improvement per iteration before stopping (for pipeline.mjs)
# MIN_IMPROVEMENT=0.005

# Blind eval concurrency (parallel questions)
# CONCURRENCY=3

# ─── Monitor Server ─────────────────────────────────────────────────────────

# Port for the browser monitor dashboard
# PORT=3000
