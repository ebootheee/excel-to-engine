# eval/.env.example — Copy to .env and fill in your values
# Usage: cp .env.example .env && nano .env

# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key (for blind-eval and auto-iteration Claude API calls)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Eval Settings ───────────────────────────────────────────────────────────

# Target accuracy to stop iteration (0.0 to 1.0)
TARGET_ACCURACY=0.90

# Maximum iteration loops before stopping
MAX_ITERATIONS=30

# Claude model for diagnosis/patching
MODEL_NAME=claude-sonnet-4-6

# Number of sheets to evaluate concurrently
EVAL_CONCURRENCY=6

# ─── Parallelization & Resource Limits ──────────────────────────────────────

# Node.js heap size in MB for child processes (per-sheet eval, blind eval sandbox)
# Increase for very large sheet modules; decrease if you're memory-constrained
NODE_HEAP_MB=8192

# Rust Rayon thread pool size for parallel parsing (0 = auto-detect from CPU cores)
# Override when you want to cap CPU usage during a parse run
# RAYON_NUM_THREADS=0

# Skip sheet modules larger than this (MB) — they will OOM a Node child process
# Increase only if you have sufficient RAM (each sheet runs in its own process)
MAX_SHEET_SIZE_MB=150

# ─── Docker Resource Limits (used by run.sh) ────────────────────────────────

# Memory limit for the Docker container (Docker format: 16g, 8g, 32g)
DOCKER_MEMORY=16g

# CPU limit for the Docker container (decimal cores: 4, 8, 0.5)
DOCKER_CPUS=4

# ─── Path Overrides (usually auto-detected) ──────────────────────────────────

# Path to rust-parser binary (auto-detected: ../pipelines/rust/target/release/rust-parser)
# RUST_PARSER_BIN=/path/to/rust-parser

# Path to Rust source directory (for auto-iteration patching)
# RUST_SRC_DIR=/path/to/pipelines/rust

# Directory containing .xlsx model files
# MODELS_DIR=./models

# Output directory for results
# OUTPUT_DIR=./output

# ─── Pipeline Settings ──────────────────────────────────────────────────────

# WebSocket port for monitor dashboard (0 = disabled)
# WS_PORT=3001

# Minimum improvement per iteration before stopping (for pipeline.mjs)
# MIN_IMPROVEMENT=0.005

# Blind eval concurrency (parallel questions)
# CONCURRENCY=3

# ─── Monitor Server ─────────────────────────────────────────────────────────

# Port for the browser monitor dashboard
# PORT=3000
